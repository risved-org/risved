{
	"name": "risved",
	"private": true,
	"version": "0.12.14",
	"type": "module",
	"bin": {
		"risved": "scripts/risved.mjs"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"release": "VERSION=$(node -p \"require('./package.json').version\") && git tag -a \"v$VERSION\" -m \"Release v$VERSION\" && git push --follow-tags"
	},
	"dependencies": {
		"@better-auth/core": "^1.5.5",
		"@better-auth/passkey": "^1.5.5",
		"@fontsource/bbh-hegarty": "^5.2.1",
		"@fontsource/cascadia-code": "^5.2.3",
		"@fontsource/mozilla-text": "^5.2.2",
		"@libsql/client": "^0.17.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"croner": "^10.0.1",
		"drizzle-orm": "^0.45.1"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@inlang/paraglide-js": "^2.10.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.0.18",
		"better-auth": "^1.5.5",
		"drizzle-kit": "^0.31.9",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	}
}
